# ============================================================
# .gitignore for C:\install-sysmon\
# Strategy: exclude noise/secrets/binaries — track deployable scripts by default
# ============================================================

# ----- SECRETS (must NEVER be committed) -----
.claude/gitrepo
.env
.env.*
.env_example
*credentials*
*.pem
*.key
*.pfx
.git-credentials

# ----- Sysmon binaries (download externally, not via repo) -----
*.exe
*.zip
*.msi
Eula.txt

# ----- Manual backup files (Thai BE date convention) -----
# Catches both naming styles: <name>_bck<date>.<ext> and <name>.<ext>_bck<date>
*_bck*
_bck_files/

# ----- Runtime / logs / DFIR collections -----
logs/
*.log
dfir-found/
dfir-tmp/

# ----- Dev workspace (large; not for agent deploy) -----
wazuh-export-log/

# ----- Local Claude Code context (project docs, todos, PAT) -----
.claude/
CLAUDE.md

# ----- Misc local scratch -----
tmp-command.md
(x86)/

# ----- Python (in case dev tools end up here) -----
__pycache__/
*.pyc
venv/
.venv/

# ----- OS / IDE -----
Thumbs.db
.DS_Store
desktop.ini
.vscode/
.idea/
*.swp
